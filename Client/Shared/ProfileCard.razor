<div class="card border-0 shadow-sm mb-4">
  <div class="card-body d-flex align-items-center gap-4">
    @if (!string.IsNullOrWhiteSpace(ImageUrl))
    {
      <img src="@ImageUrl" alt="@Name" class="rounded-circle" style="width:80px;height:80px;object-fit:cover;" />
    }
    else
    {
      <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fs-3"
           style="width:80px;height:80px;flex-shrink:0;">@(Name.Length > 0 ? Name[0].ToString().ToUpper() : "?")</div>
    }
    <div>
      <h4 class="card-title mb-1">@Name</h4>
      <p class="card-text text-muted mb-0">@Bio</p>
    </div>
  </div>
</div>

@code {
  [Parameter] public string Name { get; set; } = string.Empty;
  [Parameter] public string Bio { get; set; } = string.Empty;
  [Parameter] public string ImageUrl { get; set; } = string.Empty;
}