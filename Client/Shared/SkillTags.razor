@inject SkillService SkillService
@using SkillSnap.Shared.Models

@if (Skills != null && Skills.Count > 0)
{
  <div class="skill-tags mb-3">
    @foreach (var skill in Skills)
    {
      <span class="badge bg-primary me-1 mb-1">@skill.Name <small class="text-white-50">@skill.Level</small></span>
    }
  </div>
}
else
{
  <p class="text-muted">No skills yet.</p>
}

<hr />
<h5>Add a Skill</h5>
<div class="row g-2 align-items-end">
  <div class="col-auto">
    <input class="form-control" placeholder="Skill name" @bind="newSkillName" />
  </div>
  <div class="col-auto">
    <input class="form-control" placeholder="Level (e.g. Advanced)" @bind="newSkillLevel" />
  </div>
  <div class="col-auto">
    <button class="btn btn-success" @onclick="HandleAddSkill">+ Add Skill</button>
  </div>
</div>

@if (successMessage != null)
{
  <div class="alert alert-success mt-2">@successMessage</div>
}
@if (errorMessage != null)
{
  <div class="alert alert-danger mt-2">@errorMessage</div>
}

@code {
  [Parameter] public List<Skill> Skills { get; set; } = new();
  [Parameter] public int PortfolioUserId { get; set; }

  private string newSkillName = string.Empty;
  private string newSkillLevel = string.Empty;
  private string? successMessage;
  private string? errorMessage;

  private async Task HandleAddSkill()
  {
    errorMessage = null;
    successMessage = null;
    if (string.IsNullOrWhiteSpace(newSkillName)) return;

    var skill = new Skill
    {
      Name = newSkillName,
      Level = newSkillLevel,
      PortfolioUserId = PortfolioUserId
    };

    var (success, error) = await SkillService.AddSkillAsync(skill);
    if (!success) { errorMessage = error; return; }

    Skills.Add(skill);
    successMessage = $"'{newSkillName}' added.";
    newSkillName = string.Empty;
    newSkillLevel = string.Empty;
  }
}

