@page "/skills"
@inject SkillService SkillService
@using SkillSnap.Shared.Models

<PageTitle>Skills — SkillSnap</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Skills</h1>
  <a href="/add-skill" class="btn btn-sm btn-primary">+ Add Skill</a>
</div>

@if (errorMessage != null)
{
  <div class="alert alert-danger">@errorMessage</div>
}
else if (skills == null)
{
  <div class="loading-spinner">Loading skills...</div>
}
else if (skills.Count == 0)
{
  <p>No skills found.</p>
}
else
{
  <ul class="list-group">
    @foreach (var skill in skills)
    {
      <li class="list-group-item">
        <strong>@skill.Name</strong>
        @if (!string.IsNullOrWhiteSpace(skill.Level))
        {
          <span class="badge bg-secondary ms-2">@skill.Level</span>
        }
      </li>
    }
  </ul>
}

@code {
  private List<Skill>? skills;
  private string? errorMessage;

  protected override async Task OnInitializedAsync()
  {
    try
    {
      skills = await SkillService.GetSkillsAsync();
    }
    catch (Exception ex)
    {
      errorMessage = $"Failed to load skills: {ex.Message}";
    }
  }
}
