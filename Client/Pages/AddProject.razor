@page "/add-project"
@inject ProjectService ProjectService
@inject PortfolioUserService PortfolioUserService
@inject NavigationManager Navigation
@using SkillSnap.Shared.Models

<h3>Add a New Project</h3>

@if (users == null)
{
  <p>Loading users...</p>
}
else
{
  <EditForm Model="newProject" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
      <label class="form-label">Portfolio User</label>
      <InputSelect class="form-select" @bind-Value="newProject.PortfolioUserId">
        <option value="0">-- Select a user --</option>
        @foreach (var user in users)
        {
          <option value="@user.Id">@user.Name (ID: @user.Id)</option>
        }
      </InputSelect>
    </div>

    <div class="mb-3">
      <label class="form-label">Title</label>
      <InputText class="form-control" @bind-Value="newProject.Title" placeholder="Project title" />
      <ValidationMessage For="@(() => newProject.Title)" />
    </div>

    <div class="mb-3">
      <label class="form-label">Description</label>
      <InputTextArea class="form-control" @bind-Value="newProject.Description" placeholder="Project description" />
    </div>

    <div class="mb-3">
      <label class="form-label">Image URL</label>
      <InputText class="form-control" @bind-Value="newProject.ImageUrl" placeholder="https://..." />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
      @(isSubmitting ? "Saving..." : "Add Project")
    </button>
  </EditForm>
}

@if (errorMessage != null)
{
  <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
  private Project newProject = new();
  private List<PortfolioUser>? users;
  private string? errorMessage;
  private bool isSubmitting;

  protected override async Task OnInitializedAsync()
  {
    users = await PortfolioUserService.GetUsersAsync();
  }

  private async Task HandleSubmit()
  {
    isSubmitting = true;
    errorMessage = null;
    try
    {
      await ProjectService.AddProjectAsync(newProject);
      Navigation.NavigateTo("/projects");
    }
    catch (Exception ex)
    {
      errorMessage = $"Failed to add project: {ex.Message}";
    }
    finally
    {
      isSubmitting = false;
    }
  }
}
